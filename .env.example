# Path of Exile требует понятный User-Agent для API-клиентов.
# Формат: app/version (contact: email-or-url)
USER_AGENT=poe2-trade-helper/0.1 (contact: your-email@example.com)

# Прокси/VPN-клиент для общих исходящих HTTP-запросов, если сеть режет внешние сайты.
# Для системного VPN обычно оставь пустым: трафик пойдет через маршрут ОС.
# Для локального клиента укажи, например, http://127.0.0.1:7890 или socks5://127.0.0.1:1080.
OUTBOUND_PROXY_URL=
# Несколько endpoints для авто-переключения при сбое: разделители - запятая, точка с запятой или пробел.
# Первый живой endpoint используется как активный; при сетевой ошибке или плохом HTTP-ответе он уходит на cooldown.
OUTBOUND_PROXY_URLS=
# POE2_PROXY_URL/POE2_PROXY_URLS применяются только к PoE/trade2/MCP-запросам.
# Если они пустые, PoE-запросы используют общий OUTBOUND_PROXY_* или прямой маршрут ОС.
POE2_PROXY_URL=
POE2_PROXY_URLS=
# failover держит один активный endpoint и переключается после ошибки; round_robin чередует endpoints.
OUTBOUND_PROXY_STRATEGY=failover
# Номер endpoint из списка, начиная с 1. Если задан, авто-выбор отключается и используется выбранный endpoint.
OUTBOUND_PROXY_INDEX=
# Сколько секунд не использовать endpoint после ошибки.
OUTBOUND_PROXY_COOLDOWN_SECONDS=60
# Сколько endpoints пробовать в рамках одного запроса при ошибке.
# По умолчанию равно количеству заданных endpoints.
OUTBOUND_PROXY_FAILOVER_ATTEMPTS=
# Переключаться на другой endpoint при ответах, похожих на блокировку/недоступность.
OUTBOUND_PROXY_FAILOVER_ON_RESPONSE=true
# 429 намеренно не включен в общий failover: rate limit нужно ждать по Retry-After.
# PoE/trade2-клиент учитывает Retry-After по конкретному маршруту и может перейти на другой POE2_PROXY_URLS endpoint.
OUTBOUND_PROXY_FAILOVER_STATUS_CODES=403,407,408,421,425,500,502,503,504,520-524
# Текстовые маркеры странных HTML/JSON-ответов, после которых endpoint считается плохим.
OUTBOUND_PROXY_FAILOVER_BODY_MARKERS=access denied|temporarily unavailable|service unavailable|bad gateway|gateway timeout|cloudflare|captcha|checking your browser|ddos protection
# По умолчанию ретраятся только безопасные методы; trade2 search/exchange отдельно разрешают POST.
OUTBOUND_PROXY_FAILOVER_METHODS=GET,HEAD,OPTIONS
# true включает стандартные HTTP_PROXY/HTTPS_PROXY/ALL_PROXY/NO_PROXY из окружения.
# По умолчанию false, чтобы сервис не подхватывал случайный локальный proxy хоста.
OUTBOUND_TRUST_ENV=false

# FastAPI
PORT=8000
APP_BASE_URL=http://127.0.0.1:8000
# Публичный origin UI, если приложение открывается с отдельного внешнего origin.
# Пример формата: https://public.example.test:9443
PUBLIC_CANONICAL_ORIGIN=
# Origin API без порта, если браузер с публичного UI должен ходить в /api через другой origin.
# Пример формата: https://public.example.test
PUBLIC_API_ORIGIN=
# Необязательный список host заголовков для 308-редиректа на PUBLIC_CANONICAL_ORIGIN.
# Если не задан, для origin с явным портом автоматически используются host и host:443.
PUBLIC_REDIRECT_HOSTS=

# Админская учетка создается/обновляется при старте, только если задан ADMIN_PASSWORD.
# Если в базе нет админов, первый существующий/зарегистрированный пользователь тоже получает админку.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.local
ADMIN_DISPLAY_NAME=Admin
ADMIN_PASSWORD=

# Локальная дневная квота ИИ-функций в веб-интерфейсе.
# 0 или отрицательное значение отключает локальный лимит.
AI_DAILY_QUOTA=100

# Paths (optional overrides for future config support)
SQLITE_PATH=data/poe2_ninja.sqlite
STORAGE_DIR=storage

# OAuth не нужен для публичных trade2/search, trade2/fetch и trade2/exchange.
# Оставлено на будущее для официального https://api.pathofexile.com.
POE_ACCESS_TOKEN=
POE_CLIENT_ID=
POE_CLIENT_SECRET=
POE_REFRESH_TOKEN=

# Пауза между fetch-запросами к trade2, чтобы не упираться в rate limit.
RATE_COOLDOWN_MS=250

# Фоновый сбор market snapshots активен, пока запущено FastAPI-приложение.
# По умолчанию выбирается первая актуальная PoE2 challenge-лига из trade2/data/leagues.
MARKET_SNAPSHOT_ENABLED=true
MARKET_SNAPSHOT_LEAGUE=
MARKET_SNAPSHOT_TARGET=exalted
MARKET_SNAPSHOT_STATUS=any
MARKET_SNAPSHOT_CATEGORIES=
MARKET_SNAPSHOT_CURRENCY_TARGETS=divine,chaos
MARKET_SNAPSHOT_INTERVAL_MINUTES=15
MARKET_SNAPSHOT_EARLY_INTERVAL_MINUTES=5
MARKET_SNAPSHOT_EARLY_DAYS=2
MARKET_SNAPSHOT_LEAGUE_START=
MARKET_SNAPSHOT_LEAGUE_CHECK_MINUTES=10
MARKET_SNAPSHOT_PAUSE_SECONDS=1
MARKET_SNAPSHOT_INCLUDE_UNSUPPORTED=true
NOTIFICATION_WORKER_ENABLED=true
MARKET_HISTORY_COMPACTION_ENABLED=true
MARKET_HISTORY_COMPACTION_INTERVAL_MINUTES=360

# Рублевый фоновый сбор FunPay идет тем же циклом, что и market snapshots.
# Парсится только публичная витрина chips/209; основной ориентир - divine в ₽.
FUNPAY_RUB_SNAPSHOT_ENABLED=true
FUNPAY_RUB_SNAPSHOT_TARGET=divine

# Уровень логирования MCP-сервера: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# SMTP для подтверждения email при регистрации.
# Если SMTP_HOST/SMTP_FROM не заданы, локальный UI покажет dev-ссылку подтверждения.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# Telegram-уведомления. Пользователь указывает chat id в кабинете,
# а бот-токен хранится локально в .env.
TELEGRAM_BOT_TOKEN=
