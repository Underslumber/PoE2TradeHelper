# Path of Exile требует понятный User-Agent для API-клиентов.
# Формат: app/version (contact: email-or-url)
USER_AGENT=poe2-trade-helper/0.1 (contact: your-email@example.com)

# FastAPI
PORT=8000

# Paths (optional overrides for future config support)
SQLITE_PATH=data/poe2_ninja.sqlite
STORAGE_DIR=storage

# OAuth не нужен для публичных trade2/search, trade2/fetch и trade2/exchange.
# Оставлено на будущее для официального https://api.pathofexile.com.
POE_ACCESS_TOKEN=
POE_CLIENT_ID=
POE_CLIENT_SECRET=
POE_REFRESH_TOKEN=

# Пауза между fetch-запросами к trade2, чтобы не упираться в rate limit.
RATE_COOLDOWN_MS=250

# Уровень логирования MCP-сервера: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
