# Path of Exile требует понятный User-Agent для API-клиентов.
# Формат: app/version (contact: email-or-url)
USER_AGENT=poe2-trade-helper/0.1 (contact: your-email@example.com)

# Нужен только для официального https://api.pathofexile.com.
# Для trade2/search, trade2/fetch и trade2/exchange обычно достаточно User-Agent.
POE_ACCESS_TOKEN=

# Необязательно. Полезно, если позже добавим автоматическое обновление токена.
POE_CLIENT_ID=
POE_CLIENT_SECRET=
POE_REFRESH_TOKEN=

# Пауза между fetch-запросами к trade2, чтобы не упираться в rate limit.
RATE_COOLDOWN_MS=250
